generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Patient {
  id            String    @id @default(cuid())
  mrn           String    @unique
  title         String?
  firstName     String
  middleName    String?
  lastName      String
  preferredName String?
  dateOfBirth   DateTime
  sex           String
  genderIdentity String?
  pronouns      String?
  photoUrl      String?

  contactJson            String
  emergencyContactsJson  String   @default("[]")

  bloodType              String   @default("UNKNOWN")
  heightCm               Float?
  weightKg               Float?
  allergiesJson          String   @default("[]")
  chronicConditionsJson  String   @default("[]")
  currentMedicationsJson String   @default("[]")
  pastSurgeriesJson      String   @default("[]")
  familyHistoryJson      String   @default("[]")
  immunizationLogJson    String   @default("[]")

  insurancePoliciesJson  String   @default("[]")
  documentsJson          String   @default("[]")
  alertsJson             String   @default("[]")
  consentJson            String

  maritalStatus     String?
  occupation        String?
  preferredLanguage String    @default("English")
  ethnicity         String?

  isVip      Boolean   @default(false)
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([lastName])
  @@index([isArchived])
}

model Staff {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("STAFF")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model AppointmentType {
  id                     String        @id @default(cuid())
  name                   String
  defaultDurationMinutes Int           @default(30)
  bufferAfterMinutes     Int           @default(0)
  color                  String        @default("#1976D2")
  isActive               Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  appointments           Appointment[]
}

model Appointment {
  id                 String    @id @default(cuid())
  patientId          String
  providerId         String
  locationId         String    @default("main")
  appointmentTypeId  String
  slotStart          DateTime
  slotEnd            DateTime
  status             String    @default("SCHEDULED")
  reasonForVisit     String?
  notes              String?
  cancellationReason String?
  cancellationNote   String?
  recurringSeriesId  String?
  rescheduledFromId  String?
  rescheduledToId    String?
  checkedInAt        DateTime?
  completedAt        DateTime?
  remindersJson      String    @default("[]")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  appointmentType AppointmentType @relation(fields: [appointmentTypeId], references: [id])

  @@index([patientId])
  @@index([providerId])
  @@index([slotStart])
  @@index([status])
}
